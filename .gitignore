# Python bytecode
__pycache__/
*.pyc

# PyInstaller output — regenerable from the .spec files, which we DO keep
build/*
!build/*.spec
dist/

# Palworld save data — user game data, never commit
*.sav
*.sav.bak*
save/

# Archives / packaged releases
*.7z

# Promo drafts — local only, scrubbed from history 2026-07-22
steam_post.txt
reddit_post.md

# Local-only data/logs (untracked 2026-07-22; still bundled into the exe
# via the spec — a source checkout needs a local relic_master.json to build)
relic_master.json
summarylog.md
